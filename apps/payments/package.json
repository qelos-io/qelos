{
  "name": "@qelos/payments",
  "version": "3.11.0",
  "description": "Payments and billing service for qelos platform",
  "keywords": [
    "express",
    "mongoose",
    "payments",
    "billing",
    "qelos"
  ],
  "scripts": {
    "build": "tsc --skipLibCheck",
    "start": "node --use_strict dist/index.js",
    "dev": "npx tsx watch index.ts",
    "test": "node --test --experimental-test-module-mocks --import tsx 'server/services/tests/**/*.test.ts'"
  },
  "main": "dist/index.js",
  "author": "David Meir-Levy <davidmeirlevy@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@qelos/api-kit": "workspace:^",
    "@qelos/cache-manager": "workspace:^",
    "@qelos/global-types": "workspace:^",
    "mongoose": "^8.6.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.11",
    "typescript": "^4.9.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
