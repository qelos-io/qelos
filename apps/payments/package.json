{
  "name": "@qelos/payments",
  "version": "3.11.0",
  "description": "Payments and billing service for qelos platform",
  "keywords": [
    "express",
    "mongoose",
    "payments",
    "billing",
    "qelos"
  ],
  "scripts": {
    "build": "tsc --noEmit --skipLibCheck",
    "start": "node --import tsx --use_strict index.ts",
    "dev": "node --import tsx --watch index.ts",
    "test": "node --test --experimental-test-module-mocks --import tsx server/services/tests/checkout-service.test.ts server/services/tests/coupons-service.test.ts server/services/tests/invoices-service.test.ts server/services/tests/plans-service.test.ts server/services/tests/provider-adapter.test.ts server/services/tests/subscriptions-service.test.ts server/services/tests/webhook-service.test.ts server/controllers/tests/checkout.test.ts server/controllers/tests/plans.test.ts"
  },
  "main": "index.ts",
  "author": "David Meir-Levy <davidmeirlevy@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@qelos/api-kit": "workspace:^",
    "@qelos/cache-manager": "workspace:^",
    "@qelos/global-types": "workspace:^",
    "mongoose": "^8.6.1",
    "tsx": "^4.20.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.11",
    "typescript": "^4.9.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
