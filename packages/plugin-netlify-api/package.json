{
  "name": "@qelos/plugin-netlify-api",
  "version": "1.1.3",
  "description": "Netlify build plugin: proxy /api/* to Qelos API and inject config",
  "main": "index.js",
  "bin": {
    "qelos-netlify-patch-redirects": "./scripts/patch-redirects.cjs"
  },
  "exports": {
    ".": {
      "require": "./index.js",
      "default": "./index.js"
    },
    "./integrators": {
      "types": "./integrators/index.d.ts",
      "import": "./integrators/index.js",
      "require": "./integrators/index.js",
      "default": "./integrators/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "index.js",
    "manifest.yml",
    "functions",
    "integrators",
    "scripts"
  ],
  "author": "David Meir-Levy <davidmeirlevy@gmail.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test integrators/read-tokens.test.cjs"
  },
  "dependencies": {
    "@qelos/global-types": "workspace:^",
    "@qelos/sdk": "workspace:^"
  },
  "peerDependencies": {
    "@netlify/functions": ">=2.0.0"
  },
  "devDependencies": {
    "@netlify/functions": "^2.8.2"
  }
}
