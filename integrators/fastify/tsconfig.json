{
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "./src",
    "module": "Node16",
    "target": "ES2020",
    "outDir": "./dist",
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "sourceMap": true,
    "declaration": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "test/**/*"]
}
